{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "rosewater": "#f5e0dc",
    "flamingo": "#f2cdcd",
    "pink": "#f5c2e7",
    "mauve": "#cba6f7",
    "red": "#f38ba8",
    "maroon": "#eba0ac",
    "peach": "#fab387",
    "yellow": "#f9e2af",
    "green": "#a6e3a1",
    "teal": "#94e2d5",
    "sky": "#89dceb",
    "sapphire": "#74c7ec",
    "blue": "#89b4fa",
    "lavender": "#b4befe",
    "text": "#cdd6f4",
    "subtext1": "#bac2de",
    "subtext0": "#a6adc8",
    "overlay2": "#9399b2",
    "overlay1": "#7f849c",
    "overlay0": "#6c7086",
    "surface2": "#585b70",
    "surface1": "#45475a",
    "surface0": "#313244",
    "base": "#1e1e2e",
    "mantle": "#181825",
    "crust": "#11111b",
    "rosewater-light": "#dc8a78",
    "flamingo-light": "#dd7878",
    "pink-light": "#ea76cb",
    "mauve-light": "#8839ef",
    "red-light": "#d20f39",
    "maroon-light": "#e64553",
    "peach-light": "#fe640b",
    "yellow-light": "#df8e1d",
    "green-light": "#40a02b",
    "teal-light": "#179299",
    "sky-light": "#04a5e5",
    "sapphire-light": "#209fb5",
    "blue-light": "#1e66f5",
    "lavender-light": "#7287fd",
    "text-light": "#4c4f69",
    "subtext1-light": "#5c5f77",
    "subtext0-light": "#6c6f85",
    "overlay2-light": "#7c7f93",
    "overlay1-light": "#8c8fa1",
    "overlay0-light": "#9ca0b0",
    "surface2-light": "#acb0be",
    "surface1-light": "#bcc0cc",
    "surface0-light": "#ccd0da",
    "base-light": "#eff1f5",
    "mantle-light": "#e6e9ef",
    "crust-light": "#dce0e8"
  },
  "theme": {
    "primary": {
      "dark": "mauve",
      "light": "mauve-light"
    },
    "secondary": {
      "dark": "blue",
      "light": "blue-light"
    },
    "accent": {
      "dark": "teal",
      "light": "teal-light"
    },
    "error": {
      "dark": "red",
      "light": "red-light"
    },
    "warning": {
      "dark": "peach",
      "light": "peach-light"
    },
    "success": {
      "dark": "green",
      "light": "green-light"
    },
    "info": {
      "dark": "sapphire",
      "light": "sapphire-light"
    },
    "text": {
      "dark": "text",
      "light": "text-light"
    },
    "textMuted": {
      "dark": "overlay0",
      "light": "overlay0-light"
    },
    "background": "none",
    "backgroundPanel": "none",
    "backgroundElement": "none",
    "border": {
      "dark": "surface0",
      "light": "surface0-light"
    },
    "borderActive": {
      "dark": "surface1",
      "light": "surface1-light"
    },
    "borderSubtle": {
      "dark": "surface0",
      "light": "surface0-light"
    },
    "diffAdded": {
      "dark": "green",
      "light": "green-light"
    },
    "diffRemoved": {
      "dark": "red",
      "light": "red-light"
    },
    "diffContext": {
      "dark": "overlay0",
      "light": "overlay0-light"
    },
    "diffHunkHeader": {
      "dark": "overlay1",
      "light": "overlay1-light"
    },
    "diffHighlightAdded": {
      "dark": "green",
      "light": "green-light"
    },
    "diffHighlightRemoved": {
      "dark": "red",
      "light": "red-light"
    },
    "diffAddedBg": "none",
    "diffRemovedBg": "none",
    "diffContextBg": "none",
    "diffLineNumber": {
      "dark": "surface2",
      "light": "surface2-light"
    },
    "diffAddedLineNumberBg": "none",
    "diffRemovedLineNumberBg": "none",
    "markdownText": {
      "dark": "text",
      "light": "text-light"
    },
    "markdownHeading": {
      "dark": "mauve",
      "light": "mauve-light"
    },
    "markdownLink": {
      "dark": "blue",
      "light": "blue-light"
    },
    "markdownLinkText": {
      "dark": "teal",
      "light": "teal-light"
    },
    "markdownCode": {
      "dark": "green",
      "light": "green-light"
    },
    "markdownBlockQuote": {
      "dark": "overlay0",
      "light": "overlay0-light"
    },
    "markdownEmph": {
      "dark": "peach",
      "light": "peach-light"
    },
    "markdownStrong": {
      "dark": "yellow",
      "light": "yellow-light"
    },
    "markdownHorizontalRule": {
      "dark": "overlay0",
      "light": "overlay0-light"
    },
    "markdownListItem": {
      "dark": "mauve",
      "light": "mauve-light"
    },
    "markdownListEnumeration": {
      "dark": "teal",
      "light": "teal-light"
    },
    "markdownImage": {
      "dark": "blue",
      "light": "blue-light"
    },
    "markdownImageText": {
      "dark": "teal",
      "light": "teal-light"
    },
    "markdownCodeBlock": {
      "dark": "text",
      "light": "text-light"
    },
    "syntaxComment": {
      "dark": "overlay0",
      "light": "overlay0-light"
    },
    "syntaxKeyword": {
      "dark": "mauve",
      "light": "mauve-light"
    },
    "syntaxFunction": {
      "dark": "blue",
      "light": "blue-light"
    },
    "syntaxVariable": {
      "dark": "teal",
      "light": "teal-light"
    },
    "syntaxString": {
      "dark": "green",
      "light": "green-light"
    },
    "syntaxNumber": {
      "dark": "peach",
      "light": "peach-light"
    },
    "syntaxType": {
      "dark": "yellow",
      "light": "yellow-light"
    },
    "syntaxOperator": {
      "dark": "mauve",
      "light": "mauve-light"
    },
    "syntaxPunctuation": {
      "dark": "text",
      "light": "text-light"
    }
  }
}
