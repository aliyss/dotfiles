# ALIYSS' gitignore
# Can't share everything :')

# Ignore all files
/*
/*/

# Except the following

# General
!/.gitignore
!/README.md
!/README.org
!/phone-remote-access.md

# Images
!/images/

# Tridactyl
!/chawan/

# Emacs
!/emacs/
/emacs/*
/emacs/*/

!/emacs/init.el
!/emacs/early-init.el
!/emacs/config.org
!/emacs/eshell/
!/emacs/eshell/*
!/emacs/eshell/*/
!/emacs/images/
!/emacs/images/*
!/emacs/images/*/

# Flake
!/flake/
/flake/*/.env

# Foot
!/foot/

# Hyprland
!/hypr/
/hypr/hyprland.conf
/hypr/device_settings.conf

# Niri
!/niri/

# Tridactyl
!/tridactyl/
/tridactyl/tridactylrc

# Keymappings
!/wlr-which-key/
/wlr-which-key/config.yaml
!/xkb/

# Opencode
!/opencode/
/opencode/.gitignore
/opencode/package.json
/opencode/package-lock.json
/opencode/bun.lock
!/opencode/opencode.jsonc
!/opencode/plugins/
!/opencode/themes/
!/opencode/tui.json
